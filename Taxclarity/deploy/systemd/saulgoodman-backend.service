[Unit]
Description=Saul Goodman Backend
After=network.target

[Service]
Type=forking
User=saul
WorkingDirectory=/opt/saulgoodman/repo/Taxclarity
Environment=VENV_PATH=/opt/saulgoodman/venv
ExecStart=/bin/bash /opt/saulgoodman/repo/Taxclarity/run.sh
ExecStop=/bin/bash /opt/saulgoodman/repo/Taxclarity/stop.sh
Restart=always
RestartSec=5
TimeoutStartSec=120
TimeoutStopSec=60

[Install]
WantedBy=multi-user.target
